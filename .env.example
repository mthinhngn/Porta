LLM_GATEWAY_APP_NAME=llm-gateway
LLM_GATEWAY_ENVIRONMENT=development
LLM_GATEWAY_LOG_LEVEL=INFO
LLM_GATEWAY_CORRELATION_ID_HEADER=X-Request-ID
LLM_GATEWAY_PROVIDER_TIMEOUT_SECONDS=30
LLM_GATEWAY_REDIS_URL=redis://127.0.0.1:6379/0
# URL-safe base64 encoding of exactly 32 random bytes. Required to enable response caching.
# Generate locally: uv run python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# LLM_GATEWAY_GATEWAY_CACHE_ENCRYPTION_KEY=replace-with-a-local-secret
LLM_GATEWAY_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_GATEWAY_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
LLM_GATEWAY_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Required only for /v1/generate. Keep real values in the ignored .env file.
# Runtime uses synchronous SQLAlchemy; asyncpg is migration-only.
# LLM_GATEWAY_DATABASE_URL=postgresql+psycopg://localhost/llm_gateway
# LLM_GATEWAY_OPENAI_API_KEY=replace-with-a-local-secret
# LLM_GATEWAY_ANTHROPIC_API_KEY=replace-with-a-local-secret
# LLM_GATEWAY_GEMINI_API_KEY=replace-with-a-local-secret
LLM_GATEWAY_GENERATE_PRIMARY_PROVIDER_ADAPTER=openai_responses
LLM_GATEWAY_GENERATE_GATEWAY_MODEL=gateway-default
LLM_GATEWAY_GENERATE_OPENAI_UPSTREAM_MODEL=gpt-4.1-mini
LLM_GATEWAY_GENERATE_OPENAI_CURRENCY=USD
LLM_GATEWAY_GENERATE_OPENAI_INPUT_COST_PER_MILLION=0.4000000000
LLM_GATEWAY_GENERATE_OPENAI_CACHED_INPUT_COST_PER_MILLION=0.1000000000
LLM_GATEWAY_GENERATE_OPENAI_OUTPUT_COST_PER_MILLION=1.6000000000
LLM_GATEWAY_GENERATE_ANTHROPIC_ENABLED=false
LLM_GATEWAY_GENERATE_ANTHROPIC_ADAPTER=anthropic_messages
LLM_GATEWAY_GENERATE_ANTHROPIC_UPSTREAM_MODEL=claude-3-5-haiku-latest
LLM_GATEWAY_GENERATE_ANTHROPIC_CURRENCY=USD
LLM_GATEWAY_GENERATE_ANTHROPIC_INPUT_COST_PER_MILLION=0.8000000000
LLM_GATEWAY_GENERATE_ANTHROPIC_CACHED_INPUT_COST_PER_MILLION=0.0000000000
LLM_GATEWAY_GENERATE_ANTHROPIC_OUTPUT_COST_PER_MILLION=4.0000000000
LLM_GATEWAY_GENERATE_GEMINI_ENABLED=false
LLM_GATEWAY_GENERATE_GEMINI_ADAPTER=gemini_generate_content
LLM_GATEWAY_GENERATE_GEMINI_UPSTREAM_MODEL=gemini-2.0-flash
LLM_GATEWAY_GENERATE_GEMINI_CURRENCY=USD
LLM_GATEWAY_GENERATE_GEMINI_INPUT_COST_PER_MILLION=0.1000000000
LLM_GATEWAY_GENERATE_GEMINI_CACHED_INPUT_COST_PER_MILLION=0.0000000000
LLM_GATEWAY_GENERATE_GEMINI_OUTPUT_COST_PER_MILLION=0.4000000000
