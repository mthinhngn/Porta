LLM_GATEWAY_APP_NAME=llm-gateway
LLM_GATEWAY_ENVIRONMENT=development
LLM_GATEWAY_LOG_LEVEL=INFO
LLM_GATEWAY_CORRELATION_ID_HEADER=X-Request-ID
LLM_GATEWAY_PROVIDER_TIMEOUT_SECONDS=30
LLM_GATEWAY_OPENAI_BASE_URL=https://api.openai.com/v1
# Required only for /v1/generate. Keep real values in the ignored .env file.
# LLM_GATEWAY_DATABASE_URL=postgresql+asyncpg://localhost/llm_gateway
# LLM_GATEWAY_OPENAI_API_KEY=replace-with-a-local-secret
LLM_GATEWAY_GENERATE_PROVIDER_NAME=openai
LLM_GATEWAY_GENERATE_PROVIDER_ADAPTER=openai_responses
LLM_GATEWAY_GENERATE_GATEWAY_MODEL=gateway-default
LLM_GATEWAY_GENERATE_UPSTREAM_MODEL=gpt-4.1-mini
LLM_GATEWAY_GENERATE_CURRENCY=USD
LLM_GATEWAY_GENERATE_INPUT_COST_PER_MILLION=0.4000000000
LLM_GATEWAY_GENERATE_CACHED_INPUT_COST_PER_MILLION=0.1000000000
LLM_GATEWAY_GENERATE_OUTPUT_COST_PER_MILLION=1.6000000000
